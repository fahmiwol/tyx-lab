  "output": [{"name": "result", "type": "object", "description": "Agent action result"}],
  "tags": ["agents", "llm", "tool-use", "planning", "ai-framework", "autonomous"],
  "compatible_with": ["llm-backend", "tool-registry"],
  "used_in_recipes": ["autonomous-workflow", "ai-assistant"],
  "status": "stable",
