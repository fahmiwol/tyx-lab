{
  "id": "nodemailer-email-template",
  "name": "Nodemailer Email Template",
  "version": "1.0.0",
  "category": ["business"],
  "description": "Email dispatch via nodemailer with SMTP relay. Graceful fallback if SMTP unconfigured. Built-in HTML templates for common SaaS flows (purchase, reset, invite).",
  "input": [
    {
      "name": "to",
      "type": "string",
      "description": "Recipient email address"
    },
    {
      "name": "subject",
      "type": "string",
      "description": "Email subject"
    },
    {
      "name": "html",
      "type": "string",
      "description": "HTML email body"
    }
  ],
  "output": [
    {
      "name": "ok",
      "type": "boolean",
      "description": "Whether send succeeded or gracefully skipped"
    },
    {
      "name": "error",
      "type": "string",
      "description": "Error message if send failed"
    }
  ],
  "tags": ["email", "notification", "mailer", "template"],
  "compatible_with": ["nodejs", "backend", "api"],
  "used_in_recipes": ["user-onboarding", "transaction-alerts"],
  "status": "stable",
  "author": "Tiranyx",
  "license": "MIT"
}
