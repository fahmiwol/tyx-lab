{
  "id": "cinematic-camera-controller",
  "name": "Cinematic Camera Controller",
  "version": "1.0.0",
  "category": "3d",
  "description": "Three.js OrthographicCamera controller with preset cinematic animations (building pan, agent zoom, orbit, room sweep). Smooth easing, auto-return of manual controls, callback on completion.",
  "input": [
    { "name": "camera", "type": "THREE.OrthographicCamera", "description": "Three.js camera instance" },
    { "name": "controls", "type": "OrbitControls", "description": "Three.js OrbitControls for manual manipulation" }
  ],
  "output": [
    { "name": "isActive", "type": "boolean", "description": "Whether cinematic is playing" }
  ],
  "tags": ["3d", "threejs", "camera", "animation", "cinematic", "game-dev"],
  "compatible_with": ["nodejs", "browser", "typescript", "threejs"],
