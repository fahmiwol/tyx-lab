{
  "id": "image-with-fallback",
  "name": "Image with Fallback Component",
  "version": "1.0.0",
  "category": ["3d"],
  "description": "React component for images with inline fallback SVG on load error. Preserves dims and className. Useful for user-generated content, avatars, product photos.",
  "input": [
    {
      "name": "src",
      "type": "string",
      "description": "Image URL"
    },
    {
      "name": "alt",
      "type": "string",
      "description": "Alt text"
    }
  ],
  "output": [
    {
      "name": "element",
      "type": "JSX",
      "description": "Rendered img or fallback div"
    }
  ],
  "tags": ["react", "image", "ui", "fallback", "error-handling"],
  "compatible_with": ["react", "nextjs", "frontend"],
  "used_in_recipes": ["profile-card", "product-grid", "user-avatar"],
  "status": "stable",
  "author": "Tiranyx",
  "license": "MIT"
}
