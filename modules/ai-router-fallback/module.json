{
  "id": "ai-router-fallback",
  "name": "Multi-Provider AI Router",
  "version": "1.0.0",
  "category": ["ai"],
  "description": "Fallback AI content provider with priority: Groq (free) → Gemini (free) → Ollama (local) → Anthropic. Handles timeouts, fallback, and unified response format.",
  "input": [
    {
      "name": "prompt",
      "type": "string",
      "description": "User prompt or content request"
    },
    {
      "name": "options",
      "type": "object",
      "description": "Optional: { maxTokens, temperature, systemPrompt }"
    }
  ],
  "output": [
    {
      "name": "text",
      "type": "string",
      "description": "Generated content"
    },
    {
      "name": "provider",
      "type": "string",
      "description": "Which provider was used (groq|gemini|ollama|anthropic)"
    },
    {
      "name": "model",
      "type": "string",
      "description": "Model ID from provider"
    }
  ],
  "tags": ["ai", "content-generation", "fallback", "multi-provider"],
  "compatible_with": ["backend", "api", "nodejs"],
  "used_in_recipes": ["social-post-generator", "ai-content-writer"],
  "status": "stable",
  "author": "Tiranyx",
  "license": "MIT"
}
