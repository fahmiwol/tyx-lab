{
  "id": "social-post-scheduler",
  "name": "Social Post Auto-Scheduler",
  "version": "1.0.0",
  "category": ["business"],
  "description": "Background worker (60s interval) that publishes scheduled social posts when scheduled_at <= now(). Supports batch processing, transactional updates, and logging.",
  "input": [
    {
      "name": "checkInterval",
      "type": "number",
      "description": "Seconds between scheduler ticks (default: 60)"
    }
  ],
  "output": [
    {
      "name": "processedCount",
      "type": "number",
      "description": "Posts published in this tick"
    },
    {
      "name": "log",
      "type": "string",
      "description": "Scheduler action log"
    }
  ],
  "tags": ["scheduler", "social-media", "automation", "background-job"],
  "compatible_with": ["backend", "nodejs", "server"],
  "used_in_recipes": ["social-media-automation", "content-calendar"],
  "status": "stable",
  "author": "Tiranyx",
  "license": "MIT"
}
