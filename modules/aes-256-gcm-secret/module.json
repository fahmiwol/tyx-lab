{
  "id": "aes-256-gcm-secret",
  "name": "AES-256-GCM Secret Encrypt/Decrypt",
  "version": "1.0.0",
  "category": ["infra"],
  "description": "Encrypt/decrypt sensitive data (API keys, tokens, secrets) with AES-256-GCM. Output: base64(iv || authTag || ciphertext). Key derived from env var via SHA-256.",
  "input": [
    {
      "name": "plain",
      "type": "string",
      "description": "Plain text secret to encrypt"
    }
  ],
  "output": [
    {
      "name": "encrypted",
      "type": "string",
      "description": "Base64-encoded encrypted secret"
    }
  ],
  "tags": ["crypto", "encryption", "secrets", "database"],
  "compatible_with": ["nodejs", "backend"],
  "used_in_recipes": ["integration-secret-storage", "payment-key-vault"],
  "status": "stable",
  "author": "Tiranyx",
  "license": "MIT"
}
