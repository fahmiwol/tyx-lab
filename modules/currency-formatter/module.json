{
  "id": "currency-formatter",
  "name": "Currency Formatter & Conversion",
  "version": "1.0.0",
  "category": ["business"],
  "description": "Format and convert between IDR and USD. Rate stored in DB or env, with fallback. Display helpers for prices with/without conversions.",
  "input": [
    {
      "name": "amount",
      "type": "number",
      "description": "Amount in base currency (IDR)"
    },
    {
      "name": "rate",
      "type": "number",
      "description": "Exchange rate (IDR per 1 USD)"
    }
  ],
  "output": [
    {
      "name": "formatted",
      "type": "string",
      "description": "Formatted price string (e.g. 'Rp 150.000' or '$10.00')"
    }
  ],
  "tags": ["currency", "formatting", "billing", "localization"],
  "compatible_with": ["backend", "frontend", "saas"],
  "used_in_recipes": ["pricing-display", "payment-conversion"],
  "status": "stable",
  "author": "Tiranyx",
  "license": "MIT"
}
