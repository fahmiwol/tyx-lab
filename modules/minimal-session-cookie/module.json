{
  "id": "minimal-session-cookie",
  "name": "Minimal Session Cookie Auth",
  "version": "1.0.0",
  "category": ["business"],
  "description": "HMAC-SHA256 signed session tokens (no external auth library). Payload: base64(json).signature. Stores in httpOnly cookie with 14-day TTL.",
  "input": [
    {
      "name": "userId",
      "type": "string",
      "description": "User ID to encode in session"
    }
  ],
  "output": [
    {
      "name": "sessionToken",
      "type": "string",
      "description": "Signed session token (base64.signature format)"
    },
    {
      "name": "userId",
      "type": "string",
      "description": "Decoded user ID from session"
    }
  ],
  "tags": ["auth", "session", "cookie", "minimal"],
  "compatible_with": ["nextjs", "backend", "api"],
  "used_in_recipes": ["user-auth", "app-session"],
  "status": "stable",
  "author": "Tiranyx",
  "license": "MIT"
}
