{
  "id": "tiered-quota-resolver",
  "name": "Tiered Quota & Rate-Limit Resolver",
  "version": "1.0.0",
  "category": ["business"],
  "description": "Check daily usage quota across tiers (admin/pro/free/anon). Supports IP-based hashing for anonymous users, cookie-based auth (admin/user tokens), and coin deduction on overage.",
  "input": [
    {
      "name": "toolSlug",
      "type": "string",
      "description": "Tool identifier (e.g., 'image-upscaler')"
    },
    {
      "name": "clientIp",
      "type": "string",
      "description": "Client IP for anonymous quota tracking"
    }
  ],
  "output": [
    {
      "name": "allowed",
      "type": "boolean",
      "description": "Whether request is allowed"
    },
    {
      "name": "reason",
      "type": "string",
      "description": "Rejection reason if allowed=false"
    },
    {
      "name": "tier",
      "type": "string",
      "description": "User tier: admin|pro|free|anon"
    },
    {
      "name": "charged",
      "type": "boolean",
      "description": "Whether coin was deducted"
    }
  ],
  "tags": ["quota", "rate-limit", "billing", "auth"],
  "compatible_with": ["backend", "api", "saas"],
  "used_in_recipes": ["tool-access-control", "coin-billing"],
  "status": "stable",
  "author": "Tiranyx",
  "license": "MIT"
}
